
/**index.wxss - 今日习惯页面样式**/

/* 页面容器 */
.container {
  padding: 32rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
}

/* 头部区域 */
.header {
  text-align: center;
  margin-bottom: 48rpx;
  padding: 24rpx 0;
}

.main-title {
  font-size: 56rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
  -webkit-background-clip: text;
  color: transparent;
  letter-spacing: 2rpx;
}

.sub-title {
  color: var(--muted-foreground);
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1.6;
  opacity: 0.8;
}

/* 今日区域 */
.today-section {
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--foreground);
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
  border-radius: 4rpx;
}

/* 习惯网格 */
.habits-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 习惯卡片增强 */
.habit-card {
  background: var(--background);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid var(--border);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.habit-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
}

.habit-card:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.habit-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--foreground);
  margin-bottom: 16rpx;
  text-align: center;
}

.energy-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
  padding: 12rpx 24rpx;
  background: rgba(245, 158, 11, 0.1);
  border-radius: 20rpx;
  border: 1rpx solid rgba(245, 158, 11, 0.2);
}

.energy-value {
  font-size: 32rpx;
  color: var(--primary-gold);
  font-weight: 700;
  animation: pulse-energy 2s infinite;
}

/* 按钮增强 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary-purple) 0%, #8B5CF6 50%, var(--primary-gold) 100%);
  color: white;
  border-radius: 28rpx;
  padding: 28rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(124, 58, 237, 0.3);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s;
}

.btn-primary:active::before {
  left: 100%;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(124, 58, 237, 0.2);
}

/* 统计区域增强 */
.stats-section {
  background: linear-gradient(135deg, rgba(124, 58, 237, 0.05) 0%, rgba(245, 158, 11, 0.05) 100%);
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  margin-top: 48rpx;
  border: 1rpx solid rgba(124, 58, 237, 0.1);
  position: relative;
  overflow: hidden;
}

.stats-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
}

.stats-section {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
}

.stat-number {
  font-size: 56rpx;
  font-weight: 800;
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
  -webkit-background-clip: text;
  color: transparent;
  line-height: 1;
}

.stat-label {
  font-size: 26rpx;
  color: var(--muted-foreground);
  font-weight: 500;
  opacity: 0.8;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
  color: var(--muted-foreground);
}

.empty-state .icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-state .title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: var(--foreground);
}

.empty-state .description {
  font-size: 28rpx;
  line-height: 1.6;
  opacity: 0.7;
}

/* 动画增强 */
@keyframes pulse-energy {
  0%, 100% {
    transform: scale(1);
    filter: brightness(1);
  }
  50% {
    transform: scale(1.05);
    filter: brightness(1.2);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in-up {
  animation: fadeInUp 0.6s ease-out;
}

/* 成功状态 */
.habit-card.completed {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.05) 0%, rgba(34, 197, 94, 0.05) 100%);
  border-color: rgba(16, 185, 129, 0.3);
}

.habit-card.completed::before {
  background: var(--success);
}

.habit-card.completed .btn-primary {
  background: var(--success);
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.3);
}

.habit-card.completed .energy-info {
  background: rgba(16, 185, 129, 0.1);
  border-color: rgba(16, 185, 129, 0.2);
}

.habit-card.completed .energy-value {
  color: var(--success);
}
