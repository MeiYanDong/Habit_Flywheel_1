
/**index.wxss**/
.container {
  padding: 32rpx;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 24rpx;
  display: block;
}

.habits-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.habit-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 16rpx;
}

.habit-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #1f2937;
}

.energy-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.energy-value {
  font-size: 28rpx;
  color: #f59e0b;
  font-weight: 500;
}

.stats-section {
  display: flex;
  justify-content: space-around;
  margin-top: 48rpx;
  padding: 32rpx;
  background: white;
  border-radius: 16rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-number {
  font-size: 48rpx;
  font-weight: 700;
  color: #8b5cf6;
}

.stat-label {
  font-size: 24rpx;
  color: #6b7280;
}
