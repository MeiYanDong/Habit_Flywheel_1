
/**habits.wxss - 习惯管理页面样式**/

/* 页面容器 */
.container {
  padding: 32rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  padding-bottom: 120rpx;
}

/* 页面头部 */
.header {
  text-align: center;
  margin-bottom: 32rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
  -webkit-background-clip: text;
  color: transparent;
  margin-bottom: 16rpx;
  display: block;
}

.page-subtitle {
  font-size: 28rpx;
  color: var(--muted-foreground);
  opacity: 0.8;
  display: block;
}

/* 操作栏 */
.action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  gap: 16rpx;
}

.filter-section {
  flex: 1;
}

.filter-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: var(--background);
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
}

.filter-text {
  font-size: 28rpx;
  color: var(--foreground);
}

.filter-arrow {
  font-size: 24rpx;
  color: var(--muted-foreground);
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  white-space: nowrap;
}

.add-icon {
  font-size: 24rpx;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, rgba(124, 58, 237, 0.05), rgba(245, 158, 11, 0.05));
  border: 1rpx solid rgba(124, 58, 237, 0.1);
  margin-bottom: 32rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-number {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
  -webkit-background-clip: text;
  color: transparent;
}

.stat-label {
  font-size: 24rpx;
  color: var(--muted-foreground);
}

/* 习惯区域 */
.habits-section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 16rpx 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--foreground);
}

.toggle-icon {
  font-size: 24rpx;
  color: var(--muted-foreground);
}

.habits-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 习惯卡片 */
.habit-card {
  padding: 24rpx;
  transition: all 0.3s ease;
}

.habit-card:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.habit-card.archived {
  opacity: 0.6;
  background: var(--muted);
}

.habit-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.habit-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--foreground);
  flex: 1;
  margin-right: 16rpx;
}

.habit-actions {
  display: flex;
  gap: 8rpx;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
  background: var(--background);
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.95);
}

.edit-btn:active {
  background: rgba(59, 130, 246, 0.1);
  border-color: #3B82F6;
}

.archive-btn:active {
  background: rgba(245, 158, 11, 0.1);
  border-color: var(--primary-gold);
}

.delete-btn:active {
  background: rgba(239, 68, 68, 0.1);
  border-color: #EF4444;
}

.restore-btn:active {
  background: rgba(16, 185, 129, 0.1);
  border-color: var(--success);
}

/* 习惯详情 */
.habit-details {
  margin-bottom: 16rpx;
}

.habit-description {
  font-size: 28rpx;
  color: var(--muted-foreground);
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: block;
}

.habit-meta {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon {
  font-size: 24rpx;
}

.meta-text {
  font-size: 24rpx;
  color: var(--muted-foreground);
}

.color-indicator {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border);
}

/* 绑定信息 */
.binding-info {
  background: rgba(245, 158, 11, 0.1);
  border: 1rpx solid rgba(245, 158, 11, 0.2);
  border-radius: 16rpx;
  padding: 16rpx;
  margin-top: 16rpx;
}

.binding-text {
  font-size: 26rpx;
  color: var(--primary-gold);
  font-weight: 500;
  margin-bottom: 12rpx;
  display: block;
}

.binding-progress {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.progress-text {
  font-size: 24rpx;
  color: var(--muted-foreground);
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(245, 158, 11, 0.2);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--primary-gold);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 归档备注 */
.archived-note {
  font-size: 24rpx;
  color: var(--muted-foreground);
  font-style: italic;
  margin-top: 8rpx;
  display: block;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
  color: var(--muted-foreground);
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: var(--foreground);
}

.empty-description {
  font-size: 28rpx;
  line-height: 1.6;
  opacity: 0.7;
  margin-bottom: 32rpx;
}

/* 模态框 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 32rpx;
}

.modal-content {
  background: var(--background);
  border-radius: 24rpx;
  width: 100%;
  max-width: 600rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 0;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--foreground);
}

.close-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: none;
  background: var(--muted);
  font-size: 24rpx;
  color: var(--muted-foreground);
}

/* 表单样式 */
.habit-form {
  padding: 0 32rpx 32rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--foreground);
  font-weight: 500;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  font-size: 28rpx;
  background: var(--background);
  color: var(--foreground);
}

.form-textarea {
  width: 100%;
  padding: 24rpx;
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  font-size: 28rpx;
  background: var(--background);
  color: var(--foreground);
  min-height: 120rpx;
}

.picker-input {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  background: var(--background);
  font-size: 28rpx;
  color: var(--foreground);
}

.picker-arrow {
  font-size: 24rpx;
  color: var(--muted-foreground);
}

/* 颜色选择器 */
.color-picker {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.color-option {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
}

.color-option.selected {
  border-color: var(--foreground);
  transform: scale(1.1);
}

.color-option:active {
  transform: scale(0.95);
}

/* 表单操作 */
.form-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 40rpx;
}

.form-actions .btn-secondary,
.form-actions .btn-primary {
  flex: 1;
  padding: 24rpx;
  font-size: 28rpx;
}
