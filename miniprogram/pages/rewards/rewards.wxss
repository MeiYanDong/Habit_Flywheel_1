
/**rewards.wxss - 奖励管理页面样式**/

/* 页面容器 */
.container {
  padding: 32rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  padding-bottom: 120rpx;
}

/* 页面头部 */
.header {
  text-align: center;
  margin-bottom: 32rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
  -webkit-background-clip: text;
  color: transparent;
  margin-bottom: 16rpx;
  display: block;
}

.page-subtitle {
  font-size: 28rpx;
  color: var(--muted-foreground);
  opacity: 0.8;
  display: block;
}

/* 能量余额卡片 */
.energy-card {
  background: linear-gradient(135deg, var(--primary-gold), #FBBF24);
  color: white;
  margin-bottom: 32rpx;
  padding: 32rpx;
}

.energy-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.energy-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.energy-label {
  font-size: 26rpx;
  opacity: 0.9;
}

.energy-amount {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1;
}

.recent-energy {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.recent-label {
  font-size: 24rpx;
  opacity: 0.8;
}

.recent-amount {
  font-size: 32rpx;
  font-weight: 600;
}

.energy-tip {
  font-size: 24rpx;
  opacity: 0.8;
  font-style: italic;
}

/* 筛选标签栏 */
.filter-tabs {
  display: flex;
  background: var(--background);
  border-radius: 20rpx;
  padding: 8rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 12rpx;
  font-size: 26rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
  color: var(--muted-foreground);
}

.filter-tab.active {
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
  color: white;
  font-weight: 600;
}

/* 奖励列表 */
.rewards-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 奖励卡片 */
.reward-card {
  padding: 24rpx;
  transition: all 0.3s ease;
  border-left: 6rpx solid transparent;
}

.reward-card:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.reward-card.available {
  border-left-color: var(--success);
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.05), rgba(34, 197, 94, 0.05));
}

.reward-card.progress {
  border-left-color: var(--primary-purple);
  background: linear-gradient(135deg, rgba(124, 58, 237, 0.05), rgba(168, 85, 247, 0.05));
}

.reward-card.redeemed {
  border-left-color: var(--muted-foreground);
  background: var(--muted);
  opacity: 0.8;
}

/* 奖励头部 */
.reward-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.reward-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--foreground);
  flex: 1;
  margin-right: 16rpx;
}

.reward-actions {
  display: flex;
  gap: 8rpx;
}

.action-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  background: var(--background);
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.95);
}

.edit-btn:active {
  background: rgba(59, 130, 246, 0.1);
  border-color: #3B82F6;
}

.delete-btn:active {
  background: rgba(239, 68, 68, 0.1);
  border-color: #EF4444;
}

/* 奖励描述 */
.reward-description {
  font-size: 28rpx;
  color: var(--muted-foreground);
  line-height: 1.5;
  margin-bottom: 20rpx;
  display: block;
}

/* 进度区域 */
.progress-section {
  margin-bottom: 20rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.progress-percentage {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--foreground);
}

.energy-cost {
  font-size: 28rpx;
  color: var(--primary-gold);
  font-weight: 600;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: var(--muted);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-fill.available {
  background: var(--success);
}

.progress-fill.progress {
  background: var(--primary-purple);
}

.progress-fill.redeemed {
  background: var(--muted-foreground);
}

/* 绑定区域 */
.binding-section {
  margin-bottom: 20rpx;
}

.binding-title {
  font-size: 26rpx;
  color: var(--foreground);
  font-weight: 500;
  margin-bottom: 12rpx;
  display: block;
}

.bound-habits {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.habit-tag {
  background: rgba(124, 58, 237, 0.1);
  color: var(--primary-purple);
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(124, 58, 237, 0.2);
}

/* 主要操作按钮 */
.reward-actions-main {
  display: flex;
  justify-content: center;
}

.redeem-btn {
  background: linear-gradient(135deg, var(--success), #10B981);
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

.continue-btn {
  background: linear-gradient(135deg, var(--primary-purple), #8B5CF6);
  color: white;
  border: none;
}

.redeemed-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.redeemed-text {
  font-size: 28rpx;
  color: var(--success);
  font-weight: 600;
}

.redeemed-date {
  font-size: 24rpx;
  color: var(--muted-foreground);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
  color: var(--muted-foreground);
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: var(--foreground);
}

.empty-description {
  font-size: 28rpx;
  line-height: 1.6;
  opacity: 0.7;
  margin-bottom: 32rpx;
}

/* 浮动按钮 */
.fab {
  position: fixed;
  bottom: 104rpx;
  right: 32rpx;
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(124, 58, 237, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: all 0.3s ease;
}

.fab:active {
  transform: scale(0.95);
}

.fab-icon {
  font-size: 48rpx;
  color: white;
  font-weight: 600;
}

/* 模态框样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 32rpx;
}

.modal-content {
  background: var(--background);
  border-radius: 24rpx;
  width: 100%;
  max-width: 600rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 0;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--foreground);
}

.close-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: none;
  background: var(--muted);
  font-size: 24rpx;
  color: var(--muted-foreground);
}

/* 表单样式 */
.reward-form {
  padding: 0 32rpx 32rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--foreground);
  font-weight: 500;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  font-size: 28rpx;
  background: var(--background);
  color: var(--foreground);
}

.form-textarea {
  width: 100%;
  padding: 24rpx;
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  font-size: 28rpx;
  background: var(--background);
  color: var(--foreground);
  min-height: 120rpx;
}

.form-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 40rpx;
}

.form-actions .btn-secondary,
.form-actions .btn-primary {
  flex: 1;
  padding: 24rpx;
  font-size: 28rpx;
}

/* 习惯信息模态框 */
.habits-info {
  padding: 32rpx;
}

.habits-tip {
  font-size: 28rpx;
  color: var(--muted-foreground);
  margin-bottom: 24rpx;
  display: block;
  text-align: center;
}

.habits-list-modal {
  margin-bottom: 32rpx;
}

.habit-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  background: var(--muted);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.habit-emoji {
  font-size: 32rpx;
  width: 48rpx;
  text-align: center;
}

.habit-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.habit-name {
  font-size: 28rpx;
  color: var(--foreground);
  font-weight: 500;
}

.habit-energy {
  font-size: 24rpx;
  color: var(--primary-gold);
  font-weight: 600;
}
