
/**auth.wxss - 认证页面样式**/

/* 页面容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  padding: 48rpx 32rpx 32rpx;
  display: flex;
  flex-direction: column;
}

/* 头部区域 */
.header {
  text-align: center;
  margin-bottom: 80rpx;
  flex-shrink: 0;
}

.logo {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.logo-text {
  font-size: 80rpx;
  line-height: 1;
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
  -webkit-background-clip: text;
  color: transparent;
}

.welcome-text {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--foreground);
  margin-bottom: 16rpx;
  display: block;
}

.sub-text {
  font-size: 28rpx;
  color: var(--muted-foreground);
  opacity: 0.8;
  display: block;
}

/* 认证区域 */
.auth-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 48rpx;
}

.auth-card {
  background: var(--background);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid var(--border);
}

/* 微信登录按钮 */
.wechat-login {
  background: linear-gradient(135deg, #07C160 0%, #00A854 100%);
  color: white;
  border-radius: 28rpx;
  padding: 32rpx 48rpx;
  font-size: 36rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
  transition: all 0.3s ease;
  margin-bottom: 32rpx;
  width: 100%;
}

.wechat-login:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.2);
}

.wechat-icon {
  margin-right: 16rpx;
}

/* 分割线 */
.divider {
  display: flex;
  align-items: center;
  margin: 32rpx 0;
  gap: 16rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: var(--border);
}

.divider-text {
  font-size: 28rpx;
  color: var(--muted-foreground);
  padding: 0 16rpx;
}

/* 游客登录按钮 */
.guest-login {
  background: var(--background);
  color: var(--foreground);
  border: 2rpx solid var(--border);
  border-radius: 28rpx;
  padding: 28rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  width: 100%;
}

.guest-login:active {
  transform: scale(0.98);
  border-color: var(--primary-purple);
  color: var(--primary-purple);
}

.guest-icon {
  margin-right: 16rpx;
}

/* 功能介绍 */
.features-section {
  background: rgba(124, 58, 237, 0.05);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  border: 1rpx solid rgba(124, 58, 237, 0.1);
}

.features-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--foreground);
  margin-bottom: 32rpx;
  text-align: center;
  display: block;
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 0;
}

.feature-icon {
  font-size: 40rpx;
  width: 60rpx;
  text-align: center;
}

.feature-text {
  font-size: 28rpx;
  color: var(--foreground);
  line-height: 1.4;
  flex: 1;
}

/* 底部信息 */
.footer {
  text-align: center;
  margin-top: 48rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid var(--border);
  flex-shrink: 0;
}

.footer-text {
  font-size: 28rpx;
  color: var(--muted-foreground);
  margin-bottom: 16rpx;
  display: block;
  opacity: 0.8;
}

.version-text {
  font-size: 24rpx;
  color: var(--muted-foreground);
  opacity: 0.6;
  display: block;
}

/* 加载状态 */
.btn-primary:disabled,
.btn-secondary:disabled {
  opacity: 0.6;
  transform: none !important;
}
