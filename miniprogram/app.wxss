
/**app.wxss - 习惯飞轮小程序设计系统 V2.7**/

/* ===== CSS变量系统 ===== */
page {
  /* 主色调 - 紫金黑主题 */
  --primary-purple: #7C3AED;
  --primary-gold: #F59E0B;
  --primary-dark: #1F2937;

  /* 辅助色调 */
  --purple-light: #A78BFA;
  --purple-dark: #5B21B6;
  --gold-light: #FBBF24;
  --gold-dark: #D97706;

  /* 功能色调 */
  --success: #10B981;
  --warning: #F59E0B;
  --error: #EF4444;
  --info: #3B82F6;

  /* 中性色调 */
  --background: #ffffff;
  --foreground: #111827;
  --muted: #F3F4F6;
  --muted-foreground: #6B7280;
  --border: #E5E7EB;

  /* 全局设置 */
  background-color: #f8fafc;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  line-height: 1.5;
}

/* ===== 字体系统 ===== */
.text-xs { font-size: 24rpx; }    /* 12px */
.text-sm { font-size: 28rpx; }    /* 14px */
.text-base { font-size: 32rpx; }  /* 16px */
.text-lg { font-size: 36rpx; }    /* 18px */
.text-xl { font-size: 40rpx; }    /* 20px */
.text-2xl { font-size: 48rpx; }   /* 24px */
.text-3xl { font-size: 60rpx; }   /* 30px */

.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }
.font-bold { font-weight: 700; }

/* ===== 布局容器 ===== */
.container {
  padding: 32rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  padding-bottom: 120rpx;
}

.header {
  text-align: center;
  margin-bottom: 48rpx;
}

/* ===== 标题系统 ===== */
.page-title {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
  -webkit-background-clip: text;
  color: transparent;
  margin-bottom: 16rpx;
  display: block;
}

.page-subtitle {
  font-size: 28rpx;
  color: var(--muted-foreground);
  opacity: 0.8;
  display: block;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--foreground);
  margin-bottom: 24rpx;
  display: block;
}

/* ===== 卡片系统 ===== */
.card {
  background: var(--background);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 16rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  border: 1rpx solid var(--border);
  transition: all 0.3s ease;
}

.card:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* ===== 按钮系统 ===== */
.btn-primary {
  background: linear-gradient(135deg, var(--primary-purple), var(--purple-light));
  color: white;
  border-radius: 24rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(124, 58, 237, 0.3);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(124, 58, 237, 0.2);
}

.btn-secondary {
  background: linear-gradient(135deg, var(--primary-gold), var(--gold-light));
  color: white;
  border-radius: 24rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.3);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.btn-secondary:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(245, 158, 11, 0.2);
}

.btn-outline {
  background: transparent;
  color: var(--primary-purple);
  border: 2rpx solid var(--primary-purple);
  border-radius: 24rpx;
  padding: 22rpx 46rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.btn-outline:active {
  background: var(--primary-purple);
  color: white;
}

.btn-sm {
  padding: 16rpx 32rpx;
  font-size: 24rpx;
  border-radius: 16rpx;
}

/* ===== 统计卡片 ===== */
.stats-card {
  background: linear-gradient(135deg, rgba(124, 58, 237, 0.05), rgba(245, 158, 11, 0.05));
  border: 1rpx solid rgba(124, 58, 237, 0.1);
  margin-bottom: 32rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-number {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
  -webkit-background-clip: text;
  color: transparent;
}

.stat-label {
  font-size: 24rpx;
  color: var(--muted-foreground);
}

/* ===== 操作栏 ===== */
.action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  gap: 16rpx;
}

.filter-section {
  flex: 1;
}

.filter-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: var(--background);
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.filter-text {
  font-size: 28rpx;
  color: var(--foreground);
}

.filter-arrow {
  font-size: 24rpx;
  color: var(--muted-foreground);
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  white-space: nowrap;
}

.add-icon {
  font-size: 24rpx;
}

/* ===== 习惯列表 ===== */
.habits-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.habit-card {
  border-left: 4rpx solid var(--primary-purple);
  transition: all 0.3s ease;
}

.habit-card.archived {
  opacity: 0.6;
  background: var(--muted);
}

.habit-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.habit-info {
  flex: 1;
  margin-right: 16rpx;
}

.habit-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--foreground);
  margin-bottom: 8rpx;
  display: block;
}

.habit-description {
  font-size: 28rpx;
  color: var(--muted-foreground);
  line-height: 1.5;
  display: block;
}

.habit-actions {
  display: flex;
  gap: 8rpx;
}

.action-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  background: var(--background);
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.95);
}

.edit-btn:active {
  background: rgba(59, 130, 246, 0.1);
  border-color: #3B82F6;
}

.archive-btn:active {
  background: rgba(245, 158, 11, 0.1);
  border-color: var(--primary-gold);
}

.delete-btn:active {
  background: rgba(239, 68, 68, 0.1);
  border-color: #EF4444;
}

.restore-btn:active {
  background: rgba(16, 185, 129, 0.1);
  border-color: var(--success);
}

/* ===== 习惯详情 ===== */
.habit-details {
  margin-bottom: 16rpx;
}

.habit-meta {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon {
  font-size: 24rpx;
}

.meta-text {
  font-size: 24rpx;
  color: var(--muted-foreground);
}

.color-indicator {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border);
}

/* ===== 绑定信息 ===== */
.binding-info {
  background: rgba(245, 158, 11, 0.1);
  border: 1rpx solid rgba(245, 158, 11, 0.2);
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.binding-text {
  font-size: 26rpx;
  color: var(--primary-gold);
  font-weight: 500;
  margin-bottom: 12rpx;
  display: block;
}

.binding-progress {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.progress-text {
  font-size: 24rpx;
  color: var(--muted-foreground);
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(245, 158, 11, 0.2);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--primary-gold);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* ===== 习惯操作按钮 ===== */
.habit-action-buttons {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.habit-action-buttons .btn-sm {
  flex: 1;
}

/* ===== 奖励相关样式 ===== */
.energy-card {
  background: linear-gradient(135deg, var(--primary-gold), #FBBF24);
  color: white;
  margin-bottom: 32rpx;
  padding: 32rpx;
}

.energy-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.energy-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.energy-label {
  font-size: 26rpx;
  opacity: 0.9;
}

.energy-amount {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1;
}

.recent-energy {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.recent-label {
  font-size: 24rpx;
  opacity: 0.8;
}

.recent-amount {
  font-size: 32rpx;
  font-weight: 600;
}

.energy-tip {
  font-size: 24rpx;
  opacity: 0.8;
  font-style: italic;
}

/* ===== 筛选标签栏 ===== */
.filter-tabs {
  display: flex;
  background: var(--background);
  border-radius: 20rpx;
  padding: 8rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 12rpx;
  font-size: 26rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
  color: var(--muted-foreground);
}

.filter-tab.active {
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
  color: white;
  font-weight: 600;
}

/* ===== 奖励卡片 ===== */
.reward-card {
  border-left: 6rpx solid transparent;
}

.reward-card.available {
  border-left-color: var(--success);
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.05), rgba(34, 197, 94, 0.05));
}

.reward-card.progress {
  border-left-color: var(--primary-purple);
  background: linear-gradient(135deg, rgba(124, 58, 237, 0.05), rgba(168, 85, 247, 0.05));
}

.reward-card.redeemed {
  border-left-color: var(--muted-foreground);
  background: var(--muted);
  opacity: 0.8;
}

.reward-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.reward-info {
  flex: 1;
  margin-right: 16rpx;
}

.reward-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--foreground);
  margin-bottom: 8rpx;
  display: block;
}

.reward-description {
  font-size: 28rpx;
  color: var(--muted-foreground);
  line-height: 1.5;
  display: block;
}

/* ===== 进度相关 ===== */
.progress-section {
  margin-bottom: 20rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.progress-percentage {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--foreground);
}

.energy-cost {
  font-size: 28rpx;
  color: var(--primary-gold);
  font-weight: 600;
}

.progress-fill.available {
  background: var(--success);
}

.progress-fill.progress {
  background: var(--primary-purple);
}

.progress-fill.redeemed {
  background: var(--muted-foreground);
}

/* ===== 绑定区域 ===== */
.binding-section {
  margin-bottom: 20rpx;
}

.binding-title {
  font-size: 26rpx;
  color: var(--foreground);
  font-weight: 500;
  margin-bottom: 12rpx;
  display: block;
}

.bound-habits {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.habit-tag {
  background: rgba(124, 58, 237, 0.1);
  color: var(--primary-purple);
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(124, 58, 237, 0.2);
}

/* ===== 奖励操作 ===== */
.reward-actions-main {
  display: flex;
  justify-content: center;
}

.redeem-btn {
  background: linear-gradient(135deg, var(--success), #10B981);
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

.continue-btn {
  background: linear-gradient(135deg, var(--primary-purple), #8B5CF6);
  color: white;
  border: none;
}

.redeemed-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.redeemed-text {
  font-size: 28rpx;
  color: var(--success);
  font-weight: 600;
}

.redeemed-date {
  font-size: 24rpx;
  color: var(--muted-foreground);
}

/* ===== 浮动按钮 ===== */
.fab {
  position: fixed;
  bottom: 104rpx;
  right: 32rpx;
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(124, 58, 237, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: all 0.3s ease;
}

.fab:active {
  transform: scale(0.95);
}

.fab-icon {
  font-size: 48rpx;
  color: white;
  font-weight: 600;
}

/* ===== 空状态 ===== */
.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
  color: var(--muted-foreground);
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: var(--foreground);
}

.empty-description {
  font-size: 28rpx;
  line-height: 1.6;
  opacity: 0.7;
  margin-bottom: 32rpx;
}

/* ===== 模态框样式 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 32rpx;
}

.modal-content {
  background: var(--background);
  border-radius: 24rpx;
  width: 100%;
  max-width: 600rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 0;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--foreground);
}

.close-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: none;
  background: var(--muted);
  font-size: 24rpx;
  color: var(--muted-foreground);
}

/* ===== 表单样式 ===== */
.form {
  padding: 0 32rpx 32rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--foreground);
  font-weight: 500;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  font-size: 28rpx;
  background: var(--background);
  color: var(--foreground);
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  padding: 24rpx;
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  font-size: 28rpx;
  background: var(--background);
  color: var(--foreground);
  min-height: 120rpx;
  box-sizing: border-box;
}

/* ===== 颜色选择器 ===== */
.color-picker {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.color-option {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
}

.color-option.selected {
  border-color: var(--foreground);
  transform: scale(1.1);
}

.color-option:active {
  transform: scale(0.95);
}

/* ===== 表单操作 ===== */
.form-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 40rpx;
}

.form-actions .btn-secondary,
.form-actions .btn-primary {
  flex: 1;
  padding: 24rpx;
  font-size: 28rpx;
}

/* ===== 工具类 ===== */
.text-center { text-align: center; }
.text-left { text-align: left; }
.text-right { text-align: right; }

.flex { display: flex; }
.flex-column { flex-direction: column; }
.flex-row { flex-direction: row; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.align-center { align-items: center; }

.w-full { width: 100%; }
.h-full { height: 100%; }

.rounded-sm { border-radius: 8rpx; }
.rounded-md { border-radius: 16rpx; }
.rounded-lg { border-radius: 24rpx; }
.rounded-xl { border-radius: 32rpx; }
.rounded-full { border-radius: 50%; }

.relative { position: relative; }
.absolute { position: absolute; }

.overflow-hidden { overflow: hidden; }

/* ===== 状态样式 ===== */
.loading {
  opacity: 0.6;
  pointer-events: none;
}

.disabled {
  opacity: 0.4;
  pointer-events: none;
}

.hidden { display: none; }
.visible { display: block; }
