
/**app.wxss - 习惯飞轮小程序设计系统 V2.7**/

/* ===== 颜色系统 - 紫金黑主题 ===== */
page {
  /* 主色调 */
  --primary-purple: #7C3AED;
  --primary-gold: #F59E0B;
  --primary-dark: #1F2937;

  /* 辅助色调 */
  --purple-light: #A78BFA;
  --purple-dark: #5B21B6;
  --gold-light: #FBBF24;
  --gold-dark: #D97706;

  /* 功能色调 */
  --success: #10B981;
  --warning: #F59E0B;
  --error: #EF4444;
  --info: #3B82F6;

  /* 中性色调 */
  --background: #ffffff;
  --foreground: #111827;
  --muted: #F3F4F6;
  --muted-foreground: #6B7280;
  --border: #E5E7EB;

  /* 全局设置 */
  background-color: #f8fafc;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  line-height: 1.5;
}

/* ===== 字体系统 ===== */
.text-xs { font-size: 24rpx; }    /* 12px */
.text-sm { font-size: 28rpx; }    /* 14px */
.text-base { font-size: 32rpx; }  /* 16px */
.text-lg { font-size: 36rpx; }    /* 18px */
.text-xl { font-size: 40rpx; }    /* 20px */
.text-2xl { font-size: 48rpx; }   /* 24px */
.text-3xl { font-size: 60rpx; }   /* 30px */

.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }
.font-bold { font-weight: 700; }

/* ===== 布局容器 ===== */
.container {
  padding: 32rpx;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 48rpx;
}

/* ===== 标题系统 ===== */
.main-title {
  color: var(--foreground);
  font-size: 48rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
  -webkit-background-clip: text;
  color: transparent;
}

.sub-title {
  color: var(--muted-foreground);
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--foreground);
  margin-bottom: 24rpx;
  display: block;
}

/* ===== 卡片系统 ===== */
.card {
  background: var(--background);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 16rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  border: 1rpx solid var(--border);
  transition: all 0.3s ease;
}

.card:hover {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.habit-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 16rpx;
  position: relative;
  overflow: hidden;
}

.habit-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
}

.habit-card.completed {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.05), rgba(34, 197, 94, 0.05));
  border-color: var(--success);
}

.habit-card.completed::before {
  background: var(--success);
}

/* ===== 文字样式 ===== */
.habit-name {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--foreground);
  margin-bottom: 8rpx;
}

.energy-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.energy-value {
  font-size: 28rpx;
  color: var(--primary-gold);
  font-weight: 600;
  animation: pulse-energy 2s infinite;
}

/* ===== 按钮系统 ===== */
.btn-primary {
  background: linear-gradient(135deg, var(--primary-purple), var(--purple-light));
  color: white;
  border-radius: 24rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(124, 58, 237, 0.3);
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(124, 58, 237, 0.2);
}

.btn-secondary {
  background: linear-gradient(135deg, var(--primary-gold), var(--gold-light));
  color: white;
  border-radius: 24rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.3);
  transition: all 0.3s ease;
}

.btn-outline {
  background: transparent;
  color: var(--primary-purple);
  border: 2rpx solid var(--primary-purple);
  border-radius: 24rpx;
  padding: 22rpx 46rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.btn-outline:active {
  background: var(--primary-purple);
  color: white;
}

/* ===== 统计区域 ===== */
.stats-section {
  display: flex;
  justify-content: space-around;
  margin-top: 48rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, rgba(124, 58, 237, 0.05), rgba(245, 158, 11, 0.05));
  border-radius: 24rpx;
  border: 1rpx solid var(--border);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-number {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
  -webkit-background-clip: text;
  color: transparent;
}

.stat-label {
  font-size: 24rpx;
  color: var(--muted-foreground);
}

/* ===== 习惯网格 ===== */
.habits-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ===== 进度条系统 ===== */
.progress-container {
  width: 100%;
  background: var(--muted);
  border-radius: 20rpx;
  height: 16rpx;
  overflow: hidden;
  margin: 16rpx 0;
}

.progress-fill {
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
  height: 100%;
  border-radius: 20rpx;
  transition: all 0.5s ease-out;
}

/* ===== 徽章系统 ===== */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.badge-success {
  background: rgba(16, 185, 129, 0.1);
  color: var(--success);
  border: 1rpx solid rgba(16, 185, 129, 0.2);
}

.badge-default {
  background: var(--muted);
  color: var(--muted-foreground);
  border: 1rpx solid var(--border);
}

/* ===== 动画系统 ===== */
@keyframes pulse-energy {
  0%, 100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.1);
    opacity: 0.8;
  }
}

@keyframes completion-bounce {
  0% { transform: scale(1); }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); }
}

.completion-animation {
  animation: completion-bounce 0.6s ease-out;
}

.energy-icon {
  display: inline-block;
  animation: pulse-energy 2s infinite;
}

/* ===== 交互状态 ===== */
.hover-lift {
  transition: transform 0.2s ease;
}

.hover-lift:active {
  transform: translateY(4rpx);
}

/* ===== 阴影系统 ===== */
.shadow-sm {
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.shadow-md {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.shadow-lg {
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
}

/* ===== 间距系统 ===== */
.space-1 { margin: 8rpx; }
.space-2 { margin: 16rpx; }
.space-3 { margin: 24rpx; }
.space-4 { margin: 32rpx; }
.space-6 { margin: 48rpx; }
.space-8 { margin: 64rpx; }

.gap-1 { gap: 8rpx; }
.gap-2 { gap: 16rpx; }
.gap-3 { gap: 24rpx; }
.gap-4 { gap: 32rpx; }

/* ===== 响应式适配 ===== */
.mobile-optimized {
  padding: 32rpx 16rpx;
}

.mobile-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ===== 特殊效果 ===== */
.glass-effect {
  backdrop-filter: blur(20rpx);
  background: rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.gradient-background {
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
}

.gradient-text {
  background: linear-gradient(135deg, var(--primary-purple), var(--primary-gold));
  -webkit-background-clip: text;
  color: transparent;
}

/* ===== 工具类 ===== */
.text-center { text-align: center; }
.text-left { text-align: left; }
.text-right { text-align: right; }

.flex { display: flex; }
.flex-column { flex-direction: column; }
.flex-row { flex-direction: row; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.align-center { align-items: center; }

.w-full { width: 100%; }
.h-full { height: 100%; }

.rounded-sm { border-radius: 8rpx; }
.rounded-md { border-radius: 16rpx; }
.rounded-lg { border-radius: 24rpx; }
.rounded-xl { border-radius: 32rpx; }
.rounded-full { border-radius: 50%; }

.relative { position: relative; }
.absolute { position: absolute; }

.overflow-hidden { overflow: hidden; }

/* ===== 状态样式 ===== */
.loading {
  opacity: 0.6;
  pointer-events: none;
}

.disabled {
  opacity: 0.4;
  pointer-events: none;
}

.hidden { display: none; }
.visible { display: block; }
