/**app.wxss - 全局样式**/

/**颜色变量**/
/*主色调*/
--primary-purple: #7C3AED; /* 紫色 */
--primary-gold: #F59E0B;   /* 金色 */

/*辅助色*/
--secondary-green: #10B981;  /* 绿色 */
--secondary-red: #EF4444;    /* 红色 */
--secondary-blue: #3B82F6;   /* 蓝色 */

/*背景色*/
--bg-primary: #FFFFFF;       /* 主要背景 */
--bg-secondary: #F9FAFB;     /* 次要背景 */
--bg-tertiary: #F3F4F6;      /* 三级背景 */

/*文本颜色*/
--text-primary: #1E293B;     /* 主要文本 */
--text-secondary: #475569;   /* 次要文本 */
--text-tertiary: #64748B;    /* 三级文本 */

/*边框颜色*/
--border-color: #E2E8F0;     /* 默认边框 */

/*状态颜色*/
--success-color: #34D399;    /* 成功状态 */
--warning-color: #FBBF24;    /* 警告状态 */
--error-color: #F87171;      /* 错误状态 */

/*阴影颜色*/
--shadow-color: rgba(0, 0, 0, 0.1); /* 默认阴影 */

/**间距变量**/
--spacing-xs: 4rpx;         /* 极小间距 */
--spacing-sm: 8rpx;         /* 小间距 */
--spacing-md: 16rpx;        /* 中间距 */
--spacing-lg: 24rpx;        /* 大间距 */
--spacing-xl: 32rpx;        /* 极大间距 */

/**字体大小**/
--font-size-xs: 10rpx;       /* 极小字体 */
--font-size-sm: 12rpx;       /* 小字体 */
--font-size-md: 14rpx;       /* 中字体 */
--font-size-lg: 16rpx;       /* 大字体 */
--font-size-xl: 20rpx;       /* 极大字体 */

/**边框半径**/
--border-radius-sm: 4rpx;    /* 小圆角 */
--border-radius-md: 8rpx;    /* 中圆角 */
--border-radius-lg: 12rpx;   /* 大圆角 */

/**全局样式**/
page {
  background-color: var(--bg-secondary);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  color: var(--text-primary);
  font-size: var(--font-size-md);
  line-height: 1.6;
}

.container {
  padding: var(--spacing-lg);
  min-height: 100vh;
  box-sizing: border-box;
}

/**排版**/
.main-title {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--primary-purple);
  margin-bottom: var(--spacing-sm);
  display: block;
}

.sub-title {
  font-size: var(--font-size-md);
  color: var(--text-secondary);
  display: block;
  margin-bottom: var(--spacing-lg);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--spacing-md);
  display: block;
}

.card {
  background-color: var(--bg-primary);
  border-radius: var(--border-radius-md);
  box-shadow: 0 2rpx 10rpx var(--shadow-color);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-lg);
  transition: all 0.3s ease;
}

.card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 5rpx var(--shadow-color);
}

/**按钮**/
.btn-primary {
  background-color: var(--primary-purple);
  color: #fff;
  border-radius: var(--border-radius-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  font-size: var(--font-size-md);
  font-weight: 500;
  text-align: center;
  cursor: pointer;
  transition: background-color 0.3s ease;
  border: none;
  line-height: 1.4;
}

.btn-primary:hover {
  background-color: #6C2CBD;
}

.btn-primary:active {
  background-color: #5A1BAA;
  transform: scale(0.95);
}

.btn-secondary {
  background-color: var(--bg-tertiary);
  color: var(--text-primary);
  border-radius: var(--border-radius-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  font-size: var(--font-size-md);
  font-weight: 500;
  text-align: center;
  cursor: pointer;
  transition: background-color 0.3s ease;
  border: none;
  line-height: 1.4;
}

.btn-secondary:hover {
  background-color: #E5E7EB;
}

.btn-secondary:active {
  background-color: #D1D5DB;
  transform: scale(0.95);
}

/**表单**/
.form-group {
  margin-bottom: var(--spacing-lg);
}

.form-label {
  display: block;
  font-size: var(--font-size-md);
  color: var(--text-secondary);
  margin-bottom: var(--spacing-sm);
}

.form-input,
.form-textarea {
  width: 100%;
  padding: var(--spacing-md);
  font-size: var(--font-size-md);
  color: var(--text-primary);
  background-color: var(--bg-primary);
  border: 1rpx solid var(--border-color);
  border-radius: var(--border-radius-sm);
  box-sizing: border-box;
  transition: border-color 0.3s ease;
}

.form-input:focus,
.form-textarea:focus {
  border-color: var(--primary-purple);
  outline: none;
}

.form-textarea {
  height: 150rpx;
  resize: vertical;
}

/**列表**/
.list-item {
  background-color: var(--bg-primary);
  border-radius: var(--border-radius-md);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
  box-shadow: 0 1rpx 5rpx var(--shadow-color);
}

/**状态**/
.success {
  color: var(--success-color);
}

.warning {
  color: var(--warning-color);
}

.error {
  color: var(--error-color);
}

/**Flexbox**/
.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-center {
  justify-content: center;
  align-items: center;
}

.flex-between {
  justify-content: space-between;
  align-items: center;
}

/**间距**/
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }

.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }

/**头像**/
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: var(--bg-tertiary);
}

.avatar image {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

/* 加载动画 */
@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading {
  position: relative;
  overflow: hidden;
  color: transparent !important;
}

.loading::after {
  content: '';
  box-sizing: border-box;
  position: absolute;
  top: 50%;
  left: 50%;
  width: 24rpx;
  height: 24rpx;
  margin-top: -12rpx;
  margin-left: -12rpx;
  border-radius: 50%;
  border: 2rpx solid #fff;
  border-top-color: rgba(255, 255, 255, 0.6);
  animation: spin .6s linear infinite;
}

/* 浮动操作按钮 */
.fab {
  position: fixed;
  bottom: var(--spacing-xl);
  right: var(--spacing-xl);
  background-color: var(--primary-purple);
  color: white;
  border-radius: 50%;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  z-index: 100;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.fab:active {
  transform: scale(0.9);
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.2);
}

.fab-icon {
  font-size: 40rpx;
  line-height: 1;
}

/* 模态框覆盖层 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 模态框内容 */
.modal-content {
  background-color: var(--bg-primary);
  border-radius: var(--border-radius-md);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  width: 80%;
  max-height: 90%;
  overflow-y: auto;
}

/* 模态框头部 */
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-md);
  border-bottom: 1rpx solid var(--border-color);
}

.modal-title {
  font-size: var(--font-size-lg);
  font-weight: 500;
  color: var(--text-primary);
}

.close-btn {
  background: none;
  border: none;
  font-size: var(--font-size-xl);
  color: var(--text-secondary);
  cursor: pointer;
  line-height: 1;
}

/* 模态框表单 */
.reward-form {
  padding: var(--spacing-md);
}

.form-actions {
  display: flex;
  justify-content: flex-end;
  gap: var(--spacing-md);
  margin-top: var(--spacing-lg);
}

/* 标签栏 */
.filter-tabs {
  display: flex;
  background-color: var(--bg-primary);
  border-radius: var(--border-radius-md);
  box-shadow: 0 1rpx 5rpx var(--shadow-color);
  margin-bottom: var(--spacing-lg);
  overflow: hidden;
}

.filter-tab {
  flex: 1;
  padding: var(--spacing-md);
  text-align: center;
  font-size: var(--font-size-md);
  color: var(--text-secondary);
  cursor: pointer;
  transition: background-color 0.3s ease, color 0.3s ease;
}

.filter-tab:hover {
  background-color: var(--bg-tertiary);
}

.filter-tab.active {
  background-color: var(--primary-purple);
  color: white;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: var(--spacing-xl);
  background-color: var(--bg-primary);
  border-radius: var(--border-radius-md);
  box-shadow: 0 1rpx 5rpx var(--shadow-color);
}

.empty-icon {
  font-size: 60rpx;
  color: var(--text-secondary);
  margin-bottom: var(--spacing-md);
}

.empty-title {
  font-size: var(--font-size-lg);
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: var(--spacing-sm);
}

.empty-description {
  font-size: var(--font-size-md);
  color: var(--text-secondary);
  margin-bottom: var(--spacing-lg);
}

/* 奖励卡片 */
.reward-card {
  position: relative;
  overflow: hidden;
}

.reward-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--spacing-md);
}

.reward-info {
  flex: 1;
}

.reward-name {
  font-size: var(--font-size-lg);
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--spacing-xs);
}

.reward-description {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

.reward-actions {
  display: flex;
  gap: var(--spacing-sm);
}

.action-btn {
  background: none;
  border: none;
  font-size: var(--font-size-lg);
  color: var(--text-secondary);
  cursor: pointer;
  transition: color 0.3s ease;
}

.action-btn:hover {
  color: var(--primary-purple);
}

/* 进度条 */
.progress-section {
  margin-bottom: var(--spacing-md);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.progress-percentage {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

.energy-cost {
  font-size: var(--font-size-sm);
  color: var(--primary-gold);
}

.progress-bar {
  width: 100%;
  height: 10rpx;
  background-color: var(--bg-tertiary);
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: var(--primary-purple);
  width: 0;
  transition: width 0.5s ease-in-out;
}

/* 绑定习惯 */
.binding-section {
  margin-bottom: var(--spacing-md);
}

.binding-title {
  font-size: var(--font-size-md);
  color: var(--text-primary);
  margin-bottom: var(--spacing-sm);
}

.bound-habits {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-xs);
}

.habit-tag {
  background-color: var(--bg-tertiary);
  color: var(--text-secondary);
  font-size: var(--font-size-sm);
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: var(--border-radius-sm);
}

/* 主要操作按钮 */
.reward-actions-main {
  display: flex;
  justify-content: center;
  margin-top: var(--spacing-lg);
}

.redeem-btn {
  background-color: var(--secondary-green);
  color: white;
}

.continue-btn {
  background-color: var(--primary-purple);
  color: white;
}

/* 已兑换信息 */
.redeemed-info {
  text-align: center;
}

.redeemed-text {
  font-size: var(--font-size-md);
  color: var(--secondary-green);
  margin-bottom: var(--spacing-xs);
}

.redeemed-date {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

/* 能量卡片 */
.energy-card {
  background-color: var(--primary-purple);
  color: white;
  border-radius: var(--border-radius-md);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-lg);
}

.energy-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.energy-info {
  flex: 1;
}

.energy-label {
  font-size: var(--font-size-sm);
  opacity: 0.8;
  display: block;
}

.energy-amount {
  font-size: var(--font-size-lg);
  font-weight: 500;
  display: block;
}

.recent-energy {
  text-align: right;
}

.recent-label {
  font-size: var(--font-size-xs);
  opacity: 0.8;
  display: block;
}

.recent-amount {
  font-size: var(--font-size-md);
  display: block;
}

.energy-tip {
  font-size: var(--font-size-sm);
  opacity: 0.8;
  display: block;
  text-align: center;
}

/* 页面头部 */
.header {
  text-align: center;
  margin-bottom: var(--spacing-lg);
}

.page-title {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--primary-purple);
  display: block;
}

.page-subtitle {
  font-size: var(--font-size-md);
  color: var(--text-secondary);
  display: block;
  margin-top: var(--spacing-sm);
}

/* 习惯列表 */
.habits-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300rpx, 1fr));
  gap: var(--spacing-lg);
}

.habit-card {
  background-color: var(--bg-primary);
  border-radius: var(--border-radius-md);
  box-shadow: 0 2rpx 10rpx var(--shadow-color);
  padding: var(--spacing-md);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.habit-name {
  font-size: var(--font-size-lg);
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--spacing-sm);
  display: block;
}

.habit-description {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  margin-bottom: var(--spacing-md);
  display: block;
}

.energy-info {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.energy-value {
  font-size: var(--font-size-md);
  color: var(--primary-gold);
  font-weight: 500;
}

.energy-icon {
  font-size: var(--font-size-sm);
  margin-left: var(--spacing-xs);
}

/* 完成效果 */
.completion-effect {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(16, 185, 129, 0.1);
  opacity: 0;
  transition: opacity 0.5s ease;
  pointer-events: none;
}

.habit-card.completed .completion-effect {
  opacity: 1;
}

/* 统计数据 */
.stats-section {
  display: flex;
  justify-content: space-around;
  background-color: var(--bg-primary);
  border-radius: var(--border-radius-md);
  box-shadow: 0 2rpx 10rpx var(--shadow-color);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
}

.stat-item {
  text-align: center;
}

.stat-number {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--primary-purple);
  display: block;
}

.stat-label {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  display: block;
}

/* 激励信息 */
.motivation-section {
  margin-top: var(--spacing-lg);
}

.motivation-card {
  background-color: var(--bg-primary);
  border-radius: var(--border-radius-md);
  box-shadow: 0 2rpx 10rpx var(--shadow-color);
  padding: var(--spacing-lg);
}

.motivation-text {
  font-size: var(--font-size-md);
  color: var(--text-primary);
  display: block;
  text-align: center;
}

/* 绑定管理相关样式 */
.binding-modal {
  max-height: 80vh;
  overflow-y: auto;
}

.habit-info-section {
  padding: var(--spacing-md);
  background: var(--bg-secondary);
  border-radius: var(--border-radius-md);
  margin-bottom: var(--spacing-lg);
}

.habit-info-title {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  margin-bottom: var(--spacing-xs);
}

.habit-info-name {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.current-binding {
  padding: var(--spacing-md);
  background: var(--primary-purple);
  background: linear-gradient(135deg, var(--primary-purple) 0%, var(--primary-gold) 100%);
  border-radius: var(--border-radius-md);
  margin-bottom: var(--spacing-lg);
}

.current-binding-title {
  display: block;
  font-size: var(--font-size-sm);
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: var(--spacing-sm);
}

.current-reward {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.current-reward .reward-name {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: white;
}

.current-reward .btn-outline {
  background: rgba(255, 255, 255, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.3);
  color: white;
}

.rewards-section {
  margin-top: var(--spacing-lg);
}

.section-title {
  display: block;
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-md);
}

.empty-rewards {
  text-align: center;
  padding: var(--spacing-xl);
  background: var(--bg-secondary);
  border-radius: var(--border-radius-md);
}

.empty-text {
  display: block;
  font-size: var(--font-size-md);
  color: var(--text-secondary);
  margin-bottom: var(--spacing-xs);
}

.empty-hint {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--text-tertiary);
  margin-bottom: var(--spacing-lg);
}

.rewards-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.reward-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md);
  background: var(--bg-primary);
  border: 1px solid var(--border-color);
  border-radius: var(--border-radius-md);
  transition: all 0.2s ease;
}

.reward-item:hover {
  border-color: var(--primary-purple);
  box-shadow: 0 2px 8px rgba(124, 58, 237, 0.1);
  transform: translateY(-1px);
}

.reward-info {
  flex: 1;
}

.reward-info .reward-name {
  display: block;
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-xs);
}

.reward-info .reward-cost {
  font-size: var(--font-size-sm);
  color: var(--primary-gold);
  font-weight: 500;
}

.reward-progress {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  min-width: 120rpx;
}

.progress-text {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  margin-bottom: var(--spacing-xs);
}

.mini-progress-bar {
  width: 100rpx;
  height: 6rpx;
  background: var(--bg-secondary);
  border-radius: 3rpx;
  overflow: hidden;
}

.mini-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-purple), var(--primary-gold));
  border-radius: 3rpx;
  transition: width 0.3s ease;
}

/* 绑定信息卡片样式增强 */
.binding-info {
  margin-top: var(--spacing-md);
  padding: var(--spacing-md);
  background: linear-gradient(135deg, rgba(124, 58, 237, 0.1) 0%, rgba(245, 158, 11, 0.1) 100%);
  border-radius: var(--border-radius-md);
  border-left: 4rpx solid var(--primary-purple);
}

.binding-text {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--primary-purple);
  font-weight: 600;
  margin-bottom: var(--spacing-sm);
}

.binding-progress {
  margin-top: var(--spacing-sm);
}

.binding-progress .progress-text {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--text-secondary);
  margin-bottom: var(--spacing-xs);
}

.binding-progress .progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(124, 58, 237, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
}

.binding-progress .progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-purple), var(--primary-gold));
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 按钮组样式优化 */
.habit-action-buttons {
  display: flex;
  gap: var(--spacing-sm);
  margin-top: var(--spacing-md);
}

.btn-sm {
  padding: var(--spacing-xs) var(--spacing-sm);
  font-size: var(--font-size-sm);
  height: auto;
  line-height: 1.4;
}

.btn-outline {
  background: transparent;
  border: 1px solid var(--primary-gold);
  color: var(--primary-gold);
}

.btn-outline:hover {
  background: var(--primary-gold);
  color: white;
}

/* 响应式适配 */
@media (max-width: 750rpx) {
  .reward-item {
    flex-direction: column;
    align-items: flex-start;
    gap: var(--spacing-sm);
  }
  
  .reward-progress {
    align-items: flex-start;
    width: 100%;
  }
  
  .mini-progress-bar {
    width: 100%;
  }
  
  .habit-action-buttons {
    flex-direction: column;
  }
}
