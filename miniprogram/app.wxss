
/**app.wxss**/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
}

/* 全局样式 */
page {
  background-color: #f8fafc;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.main-title {
  color: #1f2937;
  font-size: 48rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.sub-title {
  color: #6b7280;
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

.card {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.btn-primary {
  background: linear-gradient(135deg, #8b5cf6 0%, #a855f7 100%);
  color: white;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.btn-outline {
  background: transparent;
  color: #8b5cf6;
  border: 2rpx solid #8b5cf6;
  border-radius: 12rpx;
  padding: 22rpx 46rpx;
  font-size: 32rpx;
}
